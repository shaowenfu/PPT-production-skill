# Google API Key（默认用于文本生成与图像生成）
GOOGLE_API_KEY=your_key_here

# DeepSeek API Key（可选：文本生成 fallback）
DEEPSEEK_API_KEY=your_key_here

# Ofox API Key（可选：Doubao 图像生成 fallback）
OFOX_API_KEY=your_key_here

# 可选配置
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OFOX_BASE_URL=https://api.ofox.ai/v1
# PPT_TEXT_MODEL=gemini-3-flash-preview
# PPT_IMAGE_MODEL=gemini-3.1-flash-image-preview
# PPT_DEFAULT_LANGUAGE=zh-CN
# PPT_DEFAULT_ASPECT_RATIO=16:9
# PPT_REQUEST_TIMEOUT_SECONDS=120.0
